#!/bin/sh
#
# S50uart_bridge — Arm the in-kernel UART<->TCP bridge
#
# Configures baud rate and arms the bridge via sysfs.
# Must run AFTER the 8250 driver has probed ttyS1.  The bridge replaces
# the former userspace serialgateway daemon entirely (removed in v3.0).
#
# The bridge module (built-in) loads at boot with enable=0 and waits
# for this script to arm it — avoids racy auto-arm when /dev/ttyS1
# does not yet exist.
#
# Configuration: /userdata/etc/radio.conf
#   BRIDGE_BAUD=460800   (default: 460800)
#   BRIDGE_BIND=0.0.0.0  (default: 0.0.0.0 = all interfaces; set to
#                         127.0.0.1 to restrict to loopback and reach
#                         the bridge only via an SSH tunnel — see
#                         drivers/net/rtl8196e-uart-bridge/SECURITY.md)
#
# Skipped when radio mode is "otbr" (otbr-agent manages the UART).
#
# J. Nilo - Apr 2026
#

SYSFS="/sys/module/rtl8196e_uart_bridge/parameters"

case "$1" in
start)
    # Skip if the bridge module is not loaded (e.g. running 5.10 kernel)
    if [ ! -d "$SYSFS" ]; then
        exit 0
    fi

    # Skip if radio is configured for OTBR
    if [ -f /userdata/etc/radio.conf ] && grep -q '^MODE=otbr' /userdata/etc/radio.conf; then
        echo "Skipping uart_bridge (radio mode: otbr)"
        exit 0
    fi

    # Read baud from config, default 460800
    BAUD=460800
    if [ -f /userdata/etc/radio.conf ]; then
        val=$(grep '^BRIDGE_BAUD=' /userdata/etc/radio.conf | cut -d= -f2)
        [ -n "$val" ] && BAUD="$val"
    fi

    # Read bind address from config, default 0.0.0.0
    BIND=0.0.0.0
    if [ -f /userdata/etc/radio.conf ]; then
        val=$(grep '^BRIDGE_BIND=' /userdata/etc/radio.conf | cut -d= -f2)
        [ -n "$val" ] && BIND="$val"
    fi

    # Map eth0 led_mode to a STATUS LED brightness for the bridge to fire
    # on TCP client connect. The bridge extinguishes the LED on disconnect.
    # Users who want a different intensity can override status_led_brightness
    # later; this just wires up a sensible default.
    case "$(cat /sys/class/net/eth0/led_mode 2>/dev/null)" in
        bright) STATUS_BRIGHT=255 ;;
        dim)    STATUS_BRIGHT=60  ;;
        off)    STATUS_BRIGHT=0   ;;
        *)      STATUS_BRIGHT=255 ;;
    esac
    echo "$STATUS_BRIGHT" > "$SYSFS/status_led_brightness" 2>/dev/null || true

    # Bind the kernel trigger to the STATUS LED if not already bound.
    # (Idempotent: writing the same trigger name again is a no-op.)
    if [ -w /sys/class/leds/status/trigger ]; then
        echo uart-bridge-client > /sys/class/leds/status/trigger 2>/dev/null || true
    fi

    echo "$BAUD" > "$SYSFS/baud"
    echo "$BIND" > "$SYSFS/bind_addr"
    echo 1 > "$SYSFS/enable"

    # The kernel driver logs "armed on <tty> @ <baud> baud, listening on ..."
    # on success — no need to echo from here. Only complain on failure.
    if [ "$(cat "$SYSFS/armed")" != "1" ]; then
        echo "UART bridge failed to arm!" >&2
        exit 1
    fi
    ;;

stop)
    if [ ! -d "$SYSFS" ]; then
        exit 0
    fi

    echo 0 > "$SYSFS/enable"
    ;;

restart)
    $0 stop
    sleep 1
    $0 start
    ;;

*)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac

exit 0
