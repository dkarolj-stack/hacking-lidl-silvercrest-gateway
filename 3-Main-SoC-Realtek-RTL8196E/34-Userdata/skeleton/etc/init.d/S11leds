#!/bin/sh
#
# S11leds — Apply LED brightness mode from /userdata/etc/leds.conf
#
# Configuration file format:
#   MODE=off      All LEDs off (saves ~20 mA)
#   MODE=dim      Reduced brightness for nighttime use
#   MODE=bright   Full brightness (default if no config file)
#
# The LAN LED brightness is controlled via the Ethernet ASIC LED mode
# (LEDCREG register: direct mode = bright, scan mode = dim).
# The STATUS LED brightness is controlled via software PWM (0-255).
#
# This script only writes the LAN led_mode. The STATUS LED is forced
# to 0 here so it does NOT light up at boot before anything is ready;
# services that care (S70otbr, and in time the UART bridge hook for
# the Zigbee path) re-read led_mode and drive the STATUS LED to the
# right brightness once they actually have a reason to (otbr-agent
# up, or a Zigbee host connected on :8888).
#
# J. Nilo - April 2026
#

CONF="/userdata/etc/leds.conf"
LED_MODE="/sys/class/net/eth0/led_mode"
STATUS_LED="/sys/class/leds/status/brightness"

# Default: bright
MODE="bright"

if [ -f "$CONF" ]; then
    . "$CONF"
fi

case "$1" in
    start)
        if [ ! -f "$LED_MODE" ]; then
            exit 0
        fi
        # STATUS LED stays off until a service takes ownership.
        echo 0 > "$STATUS_LED" 2>/dev/null
        case "$MODE" in
            off)
                echo off > "$LED_MODE"
                echo "LEDs: off"
                ;;
            dim)
                echo dim > "$LED_MODE"
                echo "LEDs: dim mode (STATUS LED idle until a service lights it)"
                ;;
            *)
                echo bright > "$LED_MODE"
                echo "LEDs: bright mode (STATUS LED idle until a service lights it)"
                ;;
        esac
        ;;
    stop)
        ;;
    *)
        echo "Usage: $0 {start|stop}"
        exit 1
        ;;
esac
